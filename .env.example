# Copy this file to .env and fill in your values

# Your Discord bot token — https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_token_here

# Your Discord user ID (bot owner)
BOT_OWNER_ID=your_user_id_here

# Groq API key — free at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Channel IDs
TEST_CHANNEL_ID=your_test_channel_id_here
GUILD_CHANNEL_ID=your_guild_channel_id_here
SPACE_ID=your_space_channel_id_here

# Cloudflare clearance cookie for wiki scraping (~24hr expiry)
# Get this from browser DevTools > Application > Cookies > swglegends.com
CF_CLEARANCE=your_cf_clearance_cookie_here
